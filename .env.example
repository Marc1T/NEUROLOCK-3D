# NEUROLOCK Environment Variables

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this from user secrets.
GEMINI_API_KEY=""

# MISTRAL_API_KEY: Optional alternative for Question Generation.
MISTRAL_API_KEY=""

# GROQ_API_KEY: Optional alternative for Question Generation.
GROQ_API_KEY=""

# CLAUDE_API_KEY: Optional alternative for Question Generation.
CLAUDE_API_KEY=""

APP_URL="http://localhost:3000"
